@startuml
left to right direction
skinparam packageStyle rectangle

actor User
actor "Non-Interactive Runner\n(CI/Script)" as Runner

rectangle "Mulonda" {
  usecase "Run Management Command\n(list/add/config/install/uninstall)" as UC1
  usecase "Proxy External Command\n(mulonda <cmd> <args>)" as UC2
  usecase "Parse Global Flags\n(--config, --watchlist)" as UC3
  usecase "Load Config" as UC4
  usecase "Load Watchlist" as UC5
  usecase "Match Command Against Rules" as UC6
  usecase "Prompt for Confirmation" as UC7
  usecase "Block Command" as UC8
  usecase "Execute Real Command" as UC9
}

User --> UC1
User --> UC2
Runner --> UC2

UC2 ..> UC3 : <<include>>
UC2 ..> UC4 : <<include>>
UC2 ..> UC5 : <<include>>
UC2 ..> UC6 : <<include>>
UC7 ..> UC9 : <<extend>>
UC7 ..> UC8 : <<extend>>
UC2 ..> UC7 : <<extend>>
UC2 ..> UC9 : <<extend>>
UC2 ..> UC8 : <<extend>>

@enduml
